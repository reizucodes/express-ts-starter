{
    "name": "express-ts-starter",
    "version": "1.0.0",
    "description": "Minimal Express + TypeScript starter for scalable backend projects",
    "main": "dist/index.js",
    "scripts": {
        "dev": "nodemon --watch 'src/**/*.ts' --exec 'ts-node -r tsconfig-paths/register' src/server.ts",
        "build": "tsc",
        "start": "node dist/server.js",
        "lint": "eslint . --ext .ts",
        "format": "prettier --write ."
    },
    "author": "blaisebueno",
    "license": "MIT",
    "dependencies": {
        "dotenv": "^16.5.0",
        "express": "^4.18.2",
        "mongoose": "^8.15.1"
    },
    "devDependencies": {
        "@types/express": "^4.17.17",
        "@types/node": "^20.3.1",
        "@typescript-eslint/eslint-plugin": "^5.59.11",
        "@typescript-eslint/parser": "^5.59.11",
        "eslint": "^8.41.0",
        "nodemon": "^2.0.22",
        "ts-node": "^10.9.1",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^5.1.3"
    }
}
